{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Source Inventory Schema",
  "description": "Schema for source-analyzer output. Used for model-agnostic validation — ANY model's output must conform to this schema.",
  "type": "object",
  "required": ["source_platform", "inventory", "categories", "dependency_graph", "statistics"],
  "properties": {
    "source_platform": {
      "type": "string",
      "description": "Auto-detected source platform (e.g., aws, gcp, azure)"
    },
    "inventory": {
      "type": "object",
      "required": ["infrastructure"],
      "properties": {
        "infrastructure": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["file", "type", "provider", "resources"],
            "properties": {
              "file": { "type": "string" },
              "type": { "type": "string", "enum": ["terraform", "cloudformation", "pulumi", "arm", "bicep", "other"] },
              "provider": { "type": "string" },
              "resources": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["resource_type", "name"],
                  "properties": {
                    "resource_type": { "type": "string" },
                    "name": { "type": "string" },
                    "key_config": { "type": "object" },
                    "dependencies": { "type": "array", "items": { "type": "string" } }
                  }
                }
              }
            }
          }
        },
        "kubernetes": { "type": "array" },
        "pipelines": { "type": "array" },
        "monitoring": { "type": "array" },
        "containers": { "type": "array" },
        "other": { "type": "array" }
      }
    },
    "categories": {
      "type": "object",
      "description": "Resources grouped by category for wave-based execution",
      "additionalProperties": {
        "type": "object",
        "required": ["files", "resources", "count"],
        "properties": {
          "files": { "type": "array", "items": { "type": "string" } },
          "resources": { "type": "array" },
          "count": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "dependency_graph": { "type": "object" },
    "statistics": {
      "type": "object",
      "required": ["total_files", "total_resources"],
      "properties": {
        "total_files": { "type": "integer", "minimum": 0 },
        "total_resources": { "type": "integer", "minimum": 0 },
        "by_category": { "type": "object" },
        "unrecognized_files": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
